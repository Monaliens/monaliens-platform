# Server
PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
REDIS_URL=redis://localhost:6379

# Network
RPC_URL=https://your-monad-rpc-endpoint

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# Game service URLs (internal)
HILO_SERVICE_URL=http://hilo-backend:9595
DICE_SERVICE_URL=http://dice-backend:9596
BJ_SERVICE_URL=http://bj-backend:9597
MINES_SERVICE_URL=http://mines-backend:9598
PLINKO_SERVICE_URL=http://plinko-backend:9599
KENO_SERVICE_URL=http://keno-backend:9600
LIMBO_SERVICE_URL=http://limbo-backend:9601

# GraphQL / Hasura
GRAPHQL_URL=https://your-graphql-endpoint/v1/graphql
HASURA_ADMIN_SECRET=your_hasura_admin_secret_here

# Game database names (MongoDB)
FLIP_DB_NAME=flip
KENO_DB_NAME=keno
DICE_DB_NAME=dice
LIMBO_DB_NAME=limbo
MINES_DB_NAME=mines
HILO_DB_NAME=hilo
BLACKJACK_DB_NAME=blackjack
PLINKO_DB_NAME=plinko
STAKING_DB_NAME=staking
DCBOT_DB_NAME=dcbot
