{
  "name": "@monaliens/contracts",
  "version": "1.0.0",
  "description": "MonaliensMarket smart contracts",
  "main": "index.js",
  "scripts": {
    "dev": "hardhat node",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network monad",
    "verify": "hardhat verify --network monad",
    "clean": "hardhat clean && rm -rf typechain-types",
    "lint": "solhint 'contracts/**/*.sol'",
    "size": "hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.5",
    "typechain": "^8.3.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "@openzeppelin/hardhat-upgrades": "^3.9.0",
    "dotenv": "^17.0.0",
    "ethers": "^6.15.0"
  }
}
