# Monad Testnet Configuration
MONAD_RPC_URL=http://your-rpc-host:port
MONAD_WS_URL=wss://monad-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_ID=10143
NETWORK_NAME=monad-testnet

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
DB_NAME=monad-events
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000
DB_CONNECT_TIMEOUT=10000
DB_HEARTBEAT_FREQUENCY=10000
DB_MAX_RECONNECT_ATTEMPTS=5
DB_RECONNECT_DELAY=5000

# Contract Addresses (Monad Testnet)
SPIN_CONTRACT_ADDRESS=0xdD7E9E1F5eAF313a50AEcAb1ACFb29aC9c24b195
RAFFLE_FACTORY_ADDRESS=0xA9Fa4034f68a715d9B212822Fc5E1993Bcf9B79c
OFFER_FACTORY_ADDRESSES=0xD8cb79d1c620F6737297313A44c1ac00Dd6C3Aa3

# Event Listener Configuration
BLOCK_CONFIRMATIONS=1
BATCH_SIZE=100
CACHE_TTL=5000
BLOCK_CACHE_SIZE=100
HISTORICAL_BLOCKS=1000
RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5000
HEALTH_CHECK_INTERVAL=30000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/event-listener.log

# Features
ENABLE_WEBSOCKET_NOTIFICATIONS=true
ENABLE_STARTUP_SYNC=true
ENABLE_PERIODIC_SYNC=false
STARTUP_SYNC_ONLY=true

# WebSocket Server
WS_PORT=8080

# Contracts Endpoint (optional - leave blank to use static config)
CONTRACTS_ENDPOINT=http://your-rpc-host:port

# Gas Settings (for future features)
GAS_PRICE=auto
GAS_LIMIT=500000

# Node Environment
NODE_ENV=development 