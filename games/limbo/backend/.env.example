# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Chain RPC (see AGENTS.md): HTTP 8080, WS 8081 on ovg host
RPC_URL=http://host.docker.internal:8080
WS_URL=ws://host.docker.internal:8081
# On host without Docker: http://your-rpc-host:port and ws://127.0.0.1:8081

# Limbo Contract Address (set after deployment)
LIMBO_CONTRACT_ADDRESS=0x...

# Discord API for leaderboard (optional)
DISCORD_API_URL=http://host.docker.internal:11111/api

# Port
PORT=9599
