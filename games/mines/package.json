{
  "name": "mines",
  "version": "1.0.0",
  "description": "Provably Fair Blockchain Mines Game on Monad",
  "main": "backend/server.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:mainnet": "hardhat run scripts/deploy-mainnet.js --network monadMainnet",
    "deploy:production": "hardhat run scripts/deploy-mainnet.js --network monadProduction",
    "upgrade:mainnet": "hardhat run scripts/upgrade.js --network monadMainnet",
    "upgrade:production": "hardhat run scripts/upgrade.js --network monadProduction",
    "fund": "hardhat run scripts/fund.js --network monadMainnet",
    "backend": "node backend/server.js",
    "backend:dev": "nodemon backend/server.js"
  },
  "keywords": [
    "mines",
    "blockchain",
    "monad",
    "gambling",
    "provably-fair"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "hardhat": "^2.27.1",
    "nodemon": "^3.0.1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ethers": "^6.13.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "undici": "^6.23.0",
    "ws": "^8.14.2"
  }
}
