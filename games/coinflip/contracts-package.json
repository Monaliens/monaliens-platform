    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@pythnetwork/entropy-sdk-solidity": "^2.2.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "mongodb": "^7.0.0"
  }
