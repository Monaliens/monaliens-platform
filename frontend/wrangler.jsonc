{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "monaliens-frontend",
  "compatibility_date": "2026-05-08",
  "build": {
    "command": "npm run build"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
