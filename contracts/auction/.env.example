# Hardhat / Deployment
PRIVATE_KEY=your_deployer_private_key_here

# Network RPC
RPC_URL=https://your-monad-rpc-endpoint
RPC_URL_TESTNET=https://your-monad-testnet-rpc-endpoint

# Pyth Entropy (for raffle settlement)
ENTROPY_ADDRESS=0xD458261E832415CFd3BAE5E416FdF3230ce6F134
ENTROPY_PROVIDER=0x52DeaA1c84233F7bb8C8A45baeDE41091c616506

# Backend
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
REDIS_URL=redis://localhost:6379

# IPFS (for NFT metadata)
IPFS_API_KEY=your_ipfs_api_key_here
