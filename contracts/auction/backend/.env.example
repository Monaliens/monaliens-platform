# Server
PORT=5555
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Blockchain
RPC_URL=https://monad-mainnet.g.alchemy.com/v2/your_alchemy_api_key
WSS_URL=wss://monad-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_ID=10143

# Contract Addresses (update after deployment)
AUCTION_FACTORY_ADDRESS=0x...
NFT_COLLECTION_FACTORY_ADDRESS=0x...
USER_REGISTRY_ADDRESS=0x...
VRF_ADDRESS=0x...

# Settlement Service
SETTLEMENT_PRIVATE_KEY=your_private_key_for_settlement
SETTLEMENT_INTERVAL_MS=30000

# CORS
CORS_ORIGIN=http://localhost:3000
